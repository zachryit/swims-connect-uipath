# ── Gemini (bring-your-own-key) ───────────────────────────────────────────
GOOGLE_API_KEY=                         # Google AI Studio / Vertex key
GEMINI_MODEL=gemini-3.1-pro-preview     # primary model
GEMINI_FALLBACK_MODEL=gemini-2.5-flash  # fallback
GEMINI_TRANSCRIBE_MODEL=gemini-2.5-flash # voice-note ASR

# ── Primero / SWIMS backend (reused live instance) ────────────────────────
PRIMERO_API_BASE_URL=http://localhost:3000/api/v2
PRIMERO_USERNAME=                       # service account (for local dev / connector auth)
PRIMERO_PASSWORD=
PRIMERO_ANON_USERNAME=                  # anonymous-report service account
PRIMERO_ANON_PASSWORD=

# ── Collation service directory (read-only, no auth) ──────────────────────
COLLATION_API_BASE_URL=https://api.collation.org

# ── UiPath (set after `uipath auth` / `uip login`) ────────────────────────
UIPATH_URL=
UIPATH_TENANT=
UIPATH_ACCESS_TOKEN=
UIPATH_FOLDER=

# NOTE: In the tenant, GOOGLE_API_KEY and PRIMERO_* live in Orchestrator
# Credential/Secret assets — these local values are for development only.
