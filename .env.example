# Repo-root .env — read by the agent locally (graph.py) AND the WhatsApp gateway (config.js
# loads ../.env, ../.env.uipath, then ./.env). In the TENANT the agent reads these from
# Orchestrator assets instead; these values are for local dev + the gateway host.
# Copy to .env and fill in. .env* is gitignored — never commit secrets.

# ── Gemini (bring-your-own-key) ───────────────────────────────────────────
GOOGLE_API_KEY=                          # Google AI Studio / Vertex key
GEMINI_MODEL=gemini-2.5-pro              # local-dev model (tenant uses the SWIMS_GEMINI_MODEL asset)
GEMINI_TRANSCRIBE_MODEL=gemini-2.5-pro   # voice-note ASR / image vision (gateway)

# ── Primero / SWIMS backend ───────────────────────────────────────────────
# Gateway runs on the SWIMS host, so localhost is fine there; the cloud agent uses the public
# URL from the SWIMS_PRIMERO_API_BASE_URL asset.
PRIMERO_API_BASE_URL=http://127.0.0.1:3000/api/v2
PRIMERO_ANON_USERNAME=primero_cp         # anonymous-report service account (create-only, cannot close)
PRIMERO_ANON_PASSWORD=
# Worker that OWNS anonymous reports — also the account used to attach media to those cases.
PRIMERO_WORKER_USERNAME=swims_dsw_western
PRIMERO_WORKER_PASSWORD=
PRIMERO_DEFAULT_OWNER=swims_dsw_western
# Optional explicit override for the media-attachment owner (defaults to PRIMERO_WORKER_*):
# PRIMERO_OWNER_USERNAME=
# PRIMERO_OWNER_PASSWORD=

# ── Collation service directory (read-only, no auth) ──────────────────────
COLLATION_API_BASE_URL=https://api.collation.org

# ── UiPath conversational SDK (how the gateway reaches the deployed agent) ─
UIPATH_URL=https://staging.uipath.com/<org>/DefaultTenant
UIPATH_ORG=
UIPATH_TENANT=DefaultTenant
UIPATH_ACCESS_TOKEN=                      # or UIPATH_PAT — bearer for the TS conversational SDK
UIPATH_FOLDER_ID=                         # Orchestrator folder id of the agent (e.g. Shared)
UIPATH_AGENT_ID=                          # release id of swims-connect-agent (optional; else resolved by name)
UIPATH_AGENT_NAME=swims-connect-agent

# ── Worker auth-context bridge (gateway <-> agent shared secret) ──────────
# The agent exchanges an opaque per-turn token for the worker's Primero session at this URL.
# SWIMS_BRIDGE_SECRET here MUST equal the SWIMS_BRIDGE_SECRET Orchestrator asset.
SWIMS_BRIDGE_SECRET=
SWIMS_BRIDGE_URL=https://swims.ownaradio.com/login/session-context

# ── Gateway login/health server (fronted by nginx on swims.ownaradio.com) ─
AUTH_SERVER_URL=https://swims.ownaradio.com
AUTH_SERVER_PORT=18794
WHATSAPP_BOT_NUMBER=233256590242
