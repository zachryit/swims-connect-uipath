# whatsapp-gateway/.env — OPTIONAL local overrides. The gateway reads the repo-root .env and
# .env.uipath first (UIPATH_*, PRIMERO_*, GOOGLE_API_KEY, SWIMS_BRIDGE_*), so most config lives
# there. Only put gateway-host-specific knobs here. .env* is gitignored.

# Public login/bridge URL + local bind (nginx proxies /login/ and /login/session-context here).
AUTH_SERVER_URL=https://swims.ownaradio.com
AUTH_SERVER_BIND=127.0.0.1
AUTH_SERVER_PORT=18794

# WhatsApp pairing.
WHATSAPP_BOT_NUMBER=233256590242
WHATSAPP_AUTH_DIR=./state/auth
WHATSAPP_QR_PATH=./state/wa-qr.png

# Bridge token lifetime (ms) and per-turn UiPath timeout (ms).
SWIMS_BRIDGE_TOKEN_TTL_MS=300000
AGENT_TURN_TIMEOUT_MS=75000

LOG_LEVEL=info
