# whatsapp-gateway/.env — OPTIONAL local overrides. The gateway reads the repo-root .env and
# .env.uipath first (UIPATH_*, PRIMERO_*, GOOGLE_API_KEY, SWIMS_BRIDGE_*), so most config lives
# there. Only put gateway-host-specific knobs here. .env* is gitignored.

# Public login/bridge URL + local bind (nginx proxies /login/ and /login/session-context here).
AUTH_SERVER_URL=https://swims.ownaradio.com
AUTH_SERVER_BIND=127.0.0.1
AUTH_SERVER_PORT=18794

# WhatsApp pairing.
WHATSAPP_BOT_NUMBER=233256590242
WHATSAPP_AUTH_DIR=./state/auth
WHATSAPP_QR_PATH=./state/wa-qr.png

# Bridge token lifetime (ms) and per-turn UiPath timeout (ms).
SWIMS_BRIDGE_TOKEN_TTL_MS=300000
AGENT_TURN_TIMEOUT_MS=75000

# Maestro Case (SWIMSChildProtectionCase) overdue monitor.
# The case is deployed via PAT-REST (package upload + CaseManagement release); the gateway starts
# instances via Orchestrator StartJobs and reads/cancels via PIMS — all on the user PAT it already holds.
# Set MONITOR=true + the release key (returned by POST .../odata/Releases, or `uip or` release list)
# and the Shared folder key (`uip or folders list` → Key). The gateway then starts ONE case instance
# per worker-filed SWIMS case and nudges the owner over WhatsApp when a step goes overdue (confirmed
# against live Primero via the agent). No-op while MONITOR=false.
SWIMS_MAESTRO_MONITOR=false
SWIMS_MAESTRO_RELEASE_KEY=
SWIMS_MAESTRO_FOLDER_KEY=
# Tick cadence / per-case Primero re-check interval / min gap between nudges (ms). Defaults 30m/12h/24h.
SWIMS_MAESTRO_POLL_MS=1800000
SWIMS_MAESTRO_CHECK_INTERVAL_MS=43200000
SWIMS_MAESTRO_NUDGE_COOLDOWN_MS=86400000

LOG_LEVEL=info
